{
  "openapi": "3.1.1",
  "info": {
    "title": "resend-service conversation API",
    "version": "1.0.0",
    "description": "Private Railway API for topic-centered, one-to-one email conversations. The API sends through Resend, preserves RFC reply relationships, and returns stored message bodies. Returned HTML is untrusted email content and must be sanitized before rendering. Attachments are not retrieved or returned.",
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Private conversation service host"
    }
  ],
  "security": [{ "bearerAuth": [] }],
  "tags": [
    {
      "name": "Conversations",
      "description": "Create, assign, and hydrate email conversations"
    },
    {
      "name": "Messages",
      "description": "Send messages in an existing conversation"
    },
    {
      "name": "Operations",
      "description": "Deployment readiness"
    }
  ],
  "paths": {
    "/api/health/v1": {
      "get": {
        "operationId": "getConversationApiHealth",
        "summary": "Check conversation API readiness",
        "description": "Checks required configuration and PostgreSQL connectivity without returning sensitive details.",
        "tags": ["Operations"],
        "security": [],
        "responses": {
          "200": {
            "description": "The conversation API is ready.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" },
                "example": { "status": "ok" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "503": {
            "description": "Required configuration or PostgreSQL is unavailable.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" },
                "example": { "status": "unhealthy" }
              }
            }
          }
        }
      }
    },
    "/api/conversations/v1": {
      "post": {
        "operationId": "createConversation",
        "summary": "Start a topic conversation",
        "description": "Creates the single conversation for an external topic and sends its opening email. The Idempotency-Key is retained indefinitely by this service and forwarded to Resend using a namespaced value. Repeating the same key and body returns the existing message; reusing the key with another body returns 409.",
        "tags": ["Conversations"],
        "parameters": [{ "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateConversationRequest"
              },
              "example": {
                "topic": {
                  "type": "booking",
                  "externalId": "4821",
                  "title": "Booking 4821"
                },
                "participant": {
                  "email": "person@example.com",
                  "name": "Person"
                },
                "message": { "text": "Your booking request was received." }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Conversation created and the opening email accepted by Resend.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResult" }
              }
            }
          },
          "200": {
            "description": "An earlier completed request with this idempotency key was returned.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResult" }
              }
            }
          },
          "202": {
            "description": "An earlier request with this idempotency key is still pending.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResult" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/ServerError" },
          "502": {
            "description": "Resend did not accept the email or the send result is indeterminate. The response includes the persisted conversation and message identifiers.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendFailure" }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listUnassignedConversations",
        "summary": "List unassigned inbound conversations",
        "description": "Returns inbound conversations whose RFC headers did not match a topic-backed conversation.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "assignment",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "const": "unassigned" }
          },
          { "$ref": "#/components/parameters/Limit" },
          {
            "name": "before",
            "in": "query",
            "description": "Opaque cursor returned by the previous unassigned-conversation page.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Unassigned conversation summaries.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["conversations", "page"],
                  "properties": {
                    "conversations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ConversationSummary"
                      }
                    },
                    "page": {
                      "type": "object",
                      "required": ["hasMore", "before"],
                      "properties": {
                        "hasMore": { "type": "boolean" },
                        "before": {
                          "type": ["string", "null"],
                          "format": "uuid"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/conversations/v1/{conversationId}": {
      "parameters": [{ "$ref": "#/components/parameters/ConversationId" }],
      "get": {
        "operationId": "getConversation",
        "summary": "Get a conversation by service ID",
        "tags": ["Conversations"],
        "parameters": [
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/Before" }
        ],
        "responses": {
          "200": {
            "description": "Conversation and a chronological page of messages.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Conversation" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      },
      "patch": {
        "operationId": "assignConversationTopic",
        "summary": "Assign an unassigned conversation",
        "description": "Assigns a topic exactly once. Assignment fails if the conversation already has a topic or the topic already belongs to another conversation.",
        "tags": ["Conversations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["topic"],
                "properties": {
                  "topic": { "$ref": "#/components/schemas/Topic" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assigned conversation.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Conversation" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
    "/api/conversations/v1/{conversationId}/messages": {
      "post": {
        "operationId": "createConversationMessage",
        "summary": "Continue a conversation",
        "description": "Sends a reply to an explicit parent message or, when omitted, the latest accepted or received message. In-Reply-To is the parent RFC Message-ID. References is the parent's ancestry followed by that parent identifier.",
        "tags": ["Messages"],
        "parameters": [
          { "$ref": "#/components/parameters/ConversationId" },
          { "$ref": "#/components/parameters/IdempotencyKey" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMessageRequest" },
              "example": { "text": "Here is the requested update." }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reply accepted by Resend.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResult" }
              }
            }
          },
          "200": {
            "description": "An earlier completed request with this idempotency key was returned.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResult" }
              }
            }
          },
          "202": {
            "description": "An earlier request with this idempotency key is still pending.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResult" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "500": { "$ref": "#/components/responses/ServerError" },
          "502": {
            "description": "Resend did not accept the email or the send result is indeterminate.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendFailure" }
              }
            }
          },
          "503": {
            "description": "The selected parent RFC Message-ID could not be retrieved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/conversations/v1/topics/{topicType}/{externalTopicId}": {
      "get": {
        "operationId": "getConversationByTopic",
        "summary": "Get a conversation by external topic",
        "tags": ["Conversations"],
        "parameters": [
          { "$ref": "#/components/parameters/TopicType" },
          { "$ref": "#/components/parameters/ExternalTopicId" },
          { "$ref": "#/components/parameters/Limit" },
          { "$ref": "#/components/parameters/Before" }
        ],
        "responses": {
          "200": {
            "description": "Conversation and a chronological page of messages.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Conversation" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Service credential shared only with authorized private-network callers."
      }
    },
    "parameters": {
      "ConversationId": {
        "name": "conversationId",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      },
      "TopicType": {
        "name": "topicType",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$" }
      },
      "ExternalTopicId": {
        "name": "externalTopicId",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "maxLength": 255 }
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "description": "Caller-generated key unique to one logical send request.",
        "schema": { "type": "string", "minLength": 1, "maxLength": 256 }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 50
        }
      },
      "Before": {
        "name": "before",
        "in": "query",
        "description": "Return messages older than this internal message ID.",
        "schema": { "type": "string", "format": "uuid" }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "type": "string", "enum": ["ok", "unhealthy"] }
        }
      },
      "Topic": {
        "type": "object",
        "required": ["type", "externalId", "title"],
        "properties": {
          "type": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$" },
          "externalId": { "type": "string", "minLength": 1, "maxLength": 255 },
          "title": { "type": "string", "minLength": 1 }
        }
      },
      "Participant": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "name": { "type": ["string", "null"] }
        }
      },
      "MessageContent": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "html": { "type": "string" }
        },
        "anyOf": [{ "required": ["text"] }, { "required": ["html"] }]
      },
      "CreateConversationRequest": {
        "type": "object",
        "required": ["topic", "participant", "message"],
        "properties": {
          "topic": { "$ref": "#/components/schemas/Topic" },
          "participant": { "$ref": "#/components/schemas/Participant" },
          "subject": {
            "type": "string",
            "description": "Defaults to the topic title."
          },
          "message": { "$ref": "#/components/schemas/MessageContent" }
        }
      },
      "CreateMessageRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/MessageContent" },
          {
            "type": "object",
            "properties": {
              "replyToMessageId": {
                "type": "string",
                "format": "uuid",
                "description": "Internal message ID. Defaults to the latest accepted or received message."
              }
            }
          }
        ]
      },
      "Message": {
        "type": "object",
        "required": [
          "id",
          "direction",
          "state",
          "from",
          "to",
          "subject",
          "createdAt"
        ],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "parentMessageId": { "type": ["string", "null"], "format": "uuid" },
          "direction": { "type": "string", "enum": ["inbound", "outbound"] },
          "state": {
            "type": "string",
            "enum": [
              "received",
              "pending",
              "accepted",
              "failed",
              "indeterminate"
            ]
          },
          "stateDetail": { "type": ["string", "null"] },
          "resendEmailId": { "type": ["string", "null"] },
          "internetMessageId": { "type": ["string", "null"] },
          "from": {
            "type": "object",
            "required": ["address", "name"],
            "properties": {
              "address": { "type": "string", "format": "email" },
              "name": { "type": ["string", "null"] }
            }
          },
          "to": { "type": "string", "format": "email" },
          "replyTo": { "type": ["string", "null"], "format": "email" },
          "subject": { "type": "string" },
          "text": { "type": ["string", "null"] },
          "html": {
            "type": ["string", "null"],
            "description": "Untrusted email HTML."
          },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Conversation": {
        "type": "object",
        "required": [
          "id",
          "topic",
          "title",
          "subject",
          "participant",
          "lastMessageAt",
          "createdAt",
          "updatedAt",
          "messages",
          "page"
        ],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "topic": {
            "oneOf": [
              { "$ref": "#/components/schemas/Topic" },
              { "type": "null" }
            ]
          },
          "title": { "type": "string" },
          "subject": { "type": "string" },
          "participant": { "$ref": "#/components/schemas/Participant" },
          "lastMessageAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "messages": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Message" }
          },
          "page": {
            "type": "object",
            "required": ["hasMoreBefore", "before"],
            "properties": {
              "hasMoreBefore": { "type": "boolean" },
              "before": { "type": ["string", "null"], "format": "uuid" }
            }
          }
        }
      },
      "ConversationSummary": {
        "type": "object",
        "required": ["id", "title", "participant", "lastMessageAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "participant": { "$ref": "#/components/schemas/Participant" },
          "lastMessageAt": { "type": "string", "format": "date-time" }
        }
      },
      "SendResult": {
        "type": "object",
        "required": ["conversationId", "message"],
        "properties": {
          "conversationId": { "type": "string", "format": "uuid" },
          "message": { "$ref": "#/components/schemas/Message" }
        }
      },
      "SendFailure": {
        "allOf": [
          { "$ref": "#/components/schemas/SendResult" },
          {
            "type": "object",
            "required": ["error"],
            "properties": { "error": { "type": "string" } }
          }
        ]
      },
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": { "error": { "type": "string" } }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request is malformed or failed validation.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "The bearer credential is missing or invalid.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "The requested conversation or message does not exist.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Conflict": {
        "description": "The topic, assignment, or idempotency key conflicts with existing state.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "ServerError": {
        "description": "The service is misconfigured or could not persist the operation.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  }
}
