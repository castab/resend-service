{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.conversation-api",
    "watchPatterns": [
      "/apps/conversation-api/**",
      "/packages/database/**",
      "/packages/email/**",
      "/package.json",
      "/package-lock.json",
      "/tsconfig.base.json",
      "/.dockerignore",
      "/Dockerfile.conversation-api"
    ]
  },
  "deploy": {
    "preDeployCommand": "npm run db:migrate:deploy",
    "healthcheckPath": "/api/health/v1",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
