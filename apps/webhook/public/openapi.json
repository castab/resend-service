{
  "openapi": "3.1.1",
  "info": {
    "title": "resend-service API",
    "version": "1.1.0",
    "description": "Receives signed Resend webhook events and stores selected normalized fields in PostgreSQL. Inbound email events are enriched through the Resend Receiving API and projected into email conversations without retrieving attachments. Resend delivers webhooks at least once and without a guaranteed order. Duplicate deliveries within an event family are acknowledged without creating another row.",
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Current application host"
    }
  ],
  "tags": [
    {
      "name": "Resend webhooks",
      "description": "Signed webhook deliveries from Resend"
    },
    {
      "name": "Operations",
      "description": "Deployment readiness"
    }
  ],
  "paths": {
    "/api/health/v1": {
      "get": {
        "operationId": "getWebhookHealth",
        "summary": "Check webhook readiness",
        "description": "Checks required configuration and PostgreSQL connectivity without returning sensitive details.",
        "tags": ["Operations"],
        "security": [],
        "responses": {
          "200": {
            "description": "The webhook service is ready.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" },
                "example": { "status": "ok" }
              }
            }
          },
          "400": {
            "description": "Health checks do not accept query parameters.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "503": {
            "description": "Required configuration or PostgreSQL is unavailable.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" },
                "example": { "status": "unhealthy" }
              }
            }
          }
        }
      }
    },
    "/api/webhooks/resend/v1": {
      "post": {
        "operationId": "receiveResendWebhook",
        "summary": "Receive a Resend webhook",
        "description": "Verifies the Svix signature against the exact raw request body, classifies the event, and stores its normalized fields. For email.received, the service retrieves the text, HTML, and headers from Resend and updates the conversation projection; attachments are not fetched. All three Svix headers are required and must describe the submitted body. A delivery using an svix-id already stored for the same event family is acknowledged with the same 200 response after projection succeeds. Resend may retry non-200 responses. Swagger UI cannot generate valid Svix signatures; interactive requests require header values generated for the exact raw request body.",
        "tags": ["Resend webhooks"],
        "security": [
          {
            "svixId": [],
            "svixTimestamp": [],
            "svixSignature": []
          }
        ],
        "requestBody": {
          "required": true,
          "description": "A supported Resend event serialized as JSON. The serialized bytes must be the same bytes used to generate svix-signature.",
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/EmailWebhookEvent"
                  },
                  {
                    "$ref": "#/components/schemas/ContactWebhookEvent"
                  },
                  {
                    "$ref": "#/components/schemas/DomainWebhookEvent"
                  }
                ]
              },
              "examples": {
                "emailSent": {
                  "summary": "Email accepted for delivery",
                  "value": {
                    "type": "email.sent",
                    "created_at": "2026-07-18T12:00:00.000Z",
                    "data": {
                      "email_id": "em_test123",
                      "from": "sender@example.com",
                      "to": ["recipient@example.com"],
                      "subject": "Test email",
                      "created_at": "2026-07-18T11:59:59.000Z",
                      "tags": [
                        {
                          "name": "campaign",
                          "value": "test"
                        }
                      ]
                    }
                  }
                },
                "contactCreated": {
                  "summary": "Contact created",
                  "value": {
                    "type": "contact.created",
                    "created_at": "2026-07-18T12:00:00.000Z",
                    "data": {
                      "id": "ct_test123",
                      "audience_id": "aud_test123",
                      "segment_ids": ["seg_1", "seg_2"],
                      "created_at": "2026-07-18T11:59:58.000Z",
                      "updated_at": "2026-07-18T11:59:58.000Z",
                      "email": "contact@example.com",
                      "first_name": "John",
                      "last_name": "Doe",
                      "unsubscribed": false
                    }
                  }
                },
                "domainCreated": {
                  "summary": "Domain created",
                  "value": {
                    "type": "domain.created",
                    "created_at": "2026-07-18T12:00:00.000Z",
                    "data": {
                      "id": "dom_test123",
                      "name": "example.com",
                      "status": "pending",
                      "created_at": "2026-07-18T11:59:57.000Z",
                      "region": "us-east-1",
                      "records": [
                        {
                          "record": "SPF",
                          "name": "example.com",
                          "type": "TXT",
                          "value": "v=spf1 include:_spf.resend.com ~all",
                          "ttl": "3600",
                          "status": "not_started"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The event was stored, or an event with the same svix-id was already stored for its event family.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookAcceptedResponse"
                },
                "example": {
                  "received": true
                }
              }
            }
          },
          "400": {
            "description": "One or more required Svix headers are missing, or the signed event type is unsupported.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missingHeaders": {
                    "value": {
                      "error": "Missing required Svix headers"
                    }
                  },
                  "unknownEvent": {
                    "value": {
                      "error": "Unknown event type"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "The Svix signature could not be verified against the exact raw request body.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "Invalid webhook signature"
                }
              }
            }
          },
          "500": {
            "description": "The server is missing required configuration, could not retrieve inbound content, or could not persist the event and projection. Resend can retry the delivery.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "configuration": {
                    "value": {
                      "error": "Server misconfiguration"
                    }
                  },
                  "processing": {
                    "value": {
                      "error": "Failed to process webhook"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "svixId": {
        "type": "apiKey",
        "in": "header",
        "name": "svix-id",
        "description": "Unique Svix message identifier used for signature verification and idempotency."
      },
      "svixTimestamp": {
        "type": "apiKey",
        "in": "header",
        "name": "svix-timestamp",
        "description": "Svix delivery timestamp included in signature verification."
      },
      "svixSignature": {
        "type": "apiKey",
        "in": "header",
        "name": "svix-signature",
        "description": "Svix signature generated for the exact raw request body."
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "type": "string", "enum": ["ok", "unhealthy"] }
        }
      },
      "EmailWebhookEvent": {
        "type": "object",
        "required": ["type", "created_at", "data"],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/EmailEventType"
          },
          "created_at": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "data": {
            "$ref": "#/components/schemas/EmailEventData"
          }
        }
      },
      "EmailEventType": {
        "type": "string",
        "enum": [
          "email.sent",
          "email.delivered",
          "email.delivery_delayed",
          "email.bounced",
          "email.complained",
          "email.opened",
          "email.clicked",
          "email.failed",
          "email.scheduled",
          "email.suppressed",
          "email.received"
        ]
      },
      "EmailEventData": {
        "type": "object",
        "required": ["email_id", "from", "to", "subject", "created_at"],
        "properties": {
          "email_id": {
            "type": "string",
            "description": "Resend email identifier."
          },
          "from": {
            "type": "string",
            "description": "Sender address as supplied by Resend."
          },
          "to": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "subject": {
            "type": "string"
          },
          "created_at": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "message_id": {
            "type": "string",
            "description": "RFC Message-ID supplied for inbound email.received events."
          },
          "cc": {
            "type": "array",
            "items": { "type": "string" }
          },
          "bcc": {
            "type": "array",
            "items": { "type": "string" }
          },
          "received_for": {
            "type": "array",
            "items": { "type": "string" }
          },
          "broadcast_id": {
            "type": "string"
          },
          "template_id": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WebhookTag"
            }
          },
          "bounce": {
            "$ref": "#/components/schemas/BounceData"
          },
          "click": {
            "$ref": "#/components/schemas/ClickData"
          }
        }
      },
      "WebhookTag": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "BounceData": {
        "type": "object",
        "required": ["diagnosticCode", "message", "subType", "type"],
        "properties": {
          "diagnosticCode": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          },
          "subType": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "ClickData": {
        "type": "object",
        "required": ["ipAddress", "link", "timestamp", "userAgent"],
        "properties": {
          "ipAddress": {
            "type": "string"
          },
          "link": {
            "type": "string",
            "format": "uri"
          },
          "timestamp": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "userAgent": {
            "type": "string"
          }
        }
      },
      "ContactWebhookEvent": {
        "type": "object",
        "required": ["type", "created_at", "data"],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ContactEventType"
          },
          "created_at": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "data": {
            "$ref": "#/components/schemas/ContactEventData"
          }
        }
      },
      "ContactEventType": {
        "type": "string",
        "enum": ["contact.created", "contact.updated", "contact.deleted"]
      },
      "ContactEventData": {
        "type": "object",
        "required": [
          "id",
          "segment_ids",
          "created_at",
          "updated_at",
          "email",
          "unsubscribed"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "audience_id": {
            "type": "string"
          },
          "segment_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "updated_at": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "unsubscribed": {
            "type": "boolean"
          }
        }
      },
      "DomainWebhookEvent": {
        "type": "object",
        "required": ["type", "created_at", "data"],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/DomainEventType"
          },
          "created_at": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "data": {
            "$ref": "#/components/schemas/DomainEventData"
          }
        }
      },
      "DomainEventType": {
        "type": "string",
        "enum": ["domain.created", "domain.updated", "domain.deleted"]
      },
      "DomainEventData": {
        "type": "object",
        "required": ["id", "name", "status", "created_at", "region", "records"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/DomainStatus"
          },
          "created_at": {
            "$ref": "#/components/schemas/Timestamp"
          },
          "region": {
            "$ref": "#/components/schemas/DomainRegion"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DomainRecord"
            }
          }
        }
      },
      "DomainStatus": {
        "type": "string",
        "enum": [
          "verified",
          "partially_failed",
          "failed",
          "pending",
          "not_started"
        ]
      },
      "DomainRegion": {
        "type": "string",
        "enum": ["us-east-1", "eu-west-1", "sa-east-1", "ap-northeast-1"]
      },
      "DomainRecord": {
        "type": "object",
        "required": ["record", "name", "type", "value", "ttl", "status"],
        "properties": {
          "record": {
            "type": "string",
            "enum": ["SPF", "DKIM", "Receiving MX"]
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["MX", "TXT", "CNAME"]
          },
          "value": {
            "type": "string"
          },
          "ttl": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          }
        }
      },
      "Timestamp": {
        "type": "string",
        "format": "date-time"
      },
      "WebhookAcceptedResponse": {
        "type": "object",
        "required": ["received"],
        "properties": {
          "received": {
            "type": "boolean",
            "const": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
