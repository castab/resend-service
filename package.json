{
  "name": "resend-webhooks-ingester",
  "version": "1.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "dev:test": "dotenv -e .env.test -- next dev",
    "build": "next build",
    "start": "next start",
    "lint:fix": "biome check . --write",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:postgresql": "vitest run tests/integration/postgresql.test.ts",
    "db:setup": "tsx scripts/setup-test-dbs.ts"
  },
  "dependencies": {
    "next": "16.1.1",
    "pg": "8.13.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "svix": "1.67.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "22",
    "@types/pg": "8.11.11",
    "@types/react": "19",
    "@types/react-dom": "19",
    "dotenv": "17.2.3",
    "dotenv-cli": "11.0.0",
    "tsx": "4.21.0",
    "typescript": "5",
    "vitest": "4.0.17"
  }
}
