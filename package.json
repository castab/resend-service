{
  "name": "resend-service",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "api:validate": "redocly lint public/openapi.json",
    "dev": "tsx watch src/server.ts",
    "dev:test": "dotenv -e .env.test -- tsx watch src/server.ts",
    "build": "npm run db:generate && tsc --project tsconfig.build.json && esbuild src/server.ts --bundle --platform=node --target=node22 --format=esm --packages=external --outfile=dist/server.js",
    "release:validate": "node scripts/validate-release-version.mjs",
    "start": "node dist/server.js",
    "lint:fix": "biome check . --write",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:postgresql": "vitest run tests/integration/webhook.postgresql.test.ts tests/integration/conversation.postgresql.test.ts",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:setup": "npm run db:generate && npm run db:migrate:deploy",
    "db:studio": "dotenv -e .env.test -- prisma studio",
    "db:validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "pg": "8.13.1",
    "prisma": "7.8.0",
    "svix": "1.67.0",
    "swagger-ui-dist": "5.32.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@redocly/cli": "2.39.0",
    "@types/express": "5.0.6",
    "@types/node": "22",
    "@types/pg": "8.11.11",
    "@types/swagger-ui-dist": "3.30.6",
    "dotenv-cli": "11.0.0",
    "esbuild": "0.25.12",
    "tsx": "4.21.0",
    "typescript": "5",
    "vitest": "4.0.17"
  }
}
