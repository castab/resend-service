{
  "name": "resend-service-monorepo",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "api:validate": "npm run api:validate:webhook && npm run api:validate:conversation",
    "api:validate:webhook": "redocly lint apps/webhook/public/openapi.json",
    "api:validate:conversation": "redocly lint apps/conversation-api/public/openapi.json",
    "dev:webhook": "npm run dev --workspace @resend-service/webhook",
    "dev:webhook:test": "dotenv -e .env.test -- npm run dev --workspace @resend-service/webhook",
    "dev:conversation": "npm run dev --workspace @resend-service/conversation-api",
    "dev:conversation:test": "dotenv -e .env.test -- npm run dev --workspace @resend-service/conversation-api",
    "build": "npm run db:generate && npm run build:webhook && npm run build:conversation",
    "build:webhook": "npm run build --workspace @resend-service/webhook",
    "build:conversation": "npm run build --workspace @resend-service/conversation-api",
    "start:webhook": "npm run start --workspace @resend-service/webhook",
    "start:conversation": "npm run start --workspace @resend-service/conversation-api",
    "lint:fix": "biome check . --write",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:postgresql": "vitest run apps/webhook/tests/integration/postgresql.test.ts apps/conversation-api/tests/integration/postgresql.test.ts",
    "db:generate": "npm run db:generate --workspace @resend-service/database",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace @resend-service/database",
    "db:setup": "npm run db:generate && npm run db:migrate:deploy",
    "db:studio": "dotenv -e .env.test -- npm run db:studio --workspace @resend-service/database",
    "db:validate": "npm run db:validate --workspace @resend-service/database"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@redocly/cli": "2.39.0",
    "@types/node": "22",
    "@types/pg": "8.11.11",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@types/swagger-ui-react": "5.18.0",
    "dotenv-cli": "11.0.0",
    "typescript": "5",
    "vitest": "4.0.17"
  }
}
