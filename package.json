{
  "name": "resend-service",
  "version": "1.1.0",
  "private": true,
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "api:validate": "redocly lint public/openapi.json",
    "dev": "next dev",
    "dev:test": "dotenv -e .env.test -- next dev",
    "build": "npm run db:generate && next build",
    "start": "next start",
    "lint:fix": "biome check . --write",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:postgresql": "vitest run tests/integration/postgresql.test.ts",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:setup": "npm run db:generate && npm run db:migrate:deploy",
    "db:studio": "dotenv -e .env.test -- prisma studio",
    "db:validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "17.2.3",
    "next": "16.1.1",
    "pg": "8.13.1",
    "prisma": "7.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "svix": "1.67.0",
    "swagger-ui-react": "5.32.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@redocly/cli": "2.39.0",
    "@types/node": "22",
    "@types/pg": "8.11.11",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@types/swagger-ui-react": "5.18.0",
    "dotenv-cli": "11.0.0",
    "typescript": "5",
    "vitest": "4.0.17"
  }
}
