{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "/src/**",
      "/gradle/**",
      "/gradlew",
      "/build.gradle.kts",
      "/settings.gradle.kts",
      "/gradle.properties",
      "/.dockerignore",
      "/Dockerfile"
    ]
  },
  "deploy": {
    "preDeployCommand": "/app/resend-service migrate",
    "healthcheckPath": "/api/health/v1",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
