generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model EmailWebhookEvent {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  svixId               String   @unique(map: "resend_wh_emails_svix_id_key") @map("svix_id")
  eventType            String   @map("event_type")
  webhookReceivedAt    DateTime @default(now()) @map("webhook_received_at") @db.Timestamptz(6)
  eventCreatedAt       DateTime @map("event_created_at") @db.Timestamptz(6)
  emailId              String   @map("email_id")
  fromAddress          String   @map("from_address")
  toAddresses          String[] @map("to_addresses")
  subject              String
  emailCreatedAt       DateTime @map("email_created_at") @db.Timestamptz(6)
  broadcastId          String?  @map("broadcast_id")
  templateId           String?  @map("template_id")
  tags                 Json?    @db.JsonB
  bounceType           String?  @map("bounce_type")
  bounceSubType        String?  @map("bounce_sub_type")
  bounceMessage        String?  @map("bounce_message")
  bounceDiagnosticCode String[] @default([]) @map("bounce_diagnostic_code")
  clickIpAddress       String?  @map("click_ip_address")
  clickLink            String?  @map("click_link")
  clickTimestamp       DateTime? @map("click_timestamp") @db.Timestamptz(6)
  clickUserAgent       String?  @map("click_user_agent")

  @@index([emailId], map: "idx_resend_wh_emails_email_id")
  @@index([eventType], map: "idx_resend_wh_emails_event_type")
  @@index([webhookReceivedAt], map: "idx_resend_wh_emails_webhook_received_at")
  @@index([fromAddress], map: "idx_resend_wh_emails_from_address")
  @@map("resend_wh_emails")
}

model ContactWebhookEvent {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  svixId            String   @unique(map: "resend_wh_contacts_svix_id_key") @map("svix_id")
  eventType         String   @map("event_type")
  webhookReceivedAt DateTime @default(now()) @map("webhook_received_at") @db.Timestamptz(6)
  eventCreatedAt    DateTime @map("event_created_at") @db.Timestamptz(6)
  contactId         String   @map("contact_id")
  audienceId        String?  @map("audience_id")
  segmentIds        String[] @default([]) @map("segment_ids")
  email             String
  firstName         String?  @map("first_name")
  lastName          String?  @map("last_name")
  unsubscribed      Boolean  @default(false)
  contactCreatedAt  DateTime @map("contact_created_at") @db.Timestamptz(6)
  contactUpdatedAt  DateTime @map("contact_updated_at") @db.Timestamptz(6)

  @@index([contactId], map: "idx_resend_wh_contacts_contact_id")
  @@index([eventType], map: "idx_resend_wh_contacts_event_type")
  @@index([webhookReceivedAt], map: "idx_resend_wh_contacts_webhook_received_at")
  @@index([audienceId], map: "idx_resend_wh_contacts_audience_id")
  @@index([email], map: "idx_resend_wh_contacts_email")
  @@map("resend_wh_contacts")
}

model DomainWebhookEvent {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  svixId            String   @unique(map: "resend_wh_domains_svix_id_key") @map("svix_id")
  eventType         String   @map("event_type")
  webhookReceivedAt DateTime @default(now()) @map("webhook_received_at") @db.Timestamptz(6)
  eventCreatedAt    DateTime @map("event_created_at") @db.Timestamptz(6)
  domainId          String   @map("domain_id")
  name              String
  status            String
  region            String
  domainCreatedAt   DateTime @map("domain_created_at") @db.Timestamptz(6)
  records           Json?    @db.JsonB

  @@index([domainId], map: "idx_resend_wh_domains_domain_id")
  @@index([eventType], map: "idx_resend_wh_domains_event_type")
  @@index([webhookReceivedAt], map: "idx_resend_wh_domains_webhook_received_at")
  @@index([name], map: "idx_resend_wh_domains_name")
  @@map("resend_wh_domains")
}
