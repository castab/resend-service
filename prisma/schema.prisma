generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum EmailMessageState {
  RECEIVED
  PENDING
  ACCEPTED
  FAILED
  INDETERMINATE
}

enum EmailDeliveryState {
  UNKNOWN
  DELIVERED
  DELIVERY_DELAYED
  BOUNCED
  COMPLAINED
  SUPPRESSED
  FAILED
}

model EmailConversation {
  id                 String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  routingToken       String         @unique(map: "email_conversations_routing_token_key") @default(dbgenerated("gen_random_uuid()")) @map("routing_token") @db.Uuid
  topicType          String?        @map("topic_type") @db.VarChar(64)
  externalTopicId    String?        @map("external_topic_id") @db.VarChar(255)
  title              String
  subject            String
  participantAddress String         @map("participant_address")
  participantName    String?        @map("participant_name")
  lastMessageAt      DateTime       @map("last_message_at") @db.Timestamptz(6)
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  messages           EmailMessage[]

  @@unique([topicType, externalTopicId], map: "email_conversations_topic_key")
  @@index([lastMessageAt], map: "idx_email_conversations_last_message_at")
  @@map("email_conversations")
}

model EmailMessage {
  id                          String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  conversationId              String              @map("conversation_id") @db.Uuid
  parentMessageId             String?             @map("parent_message_id") @db.Uuid
  direction                   EmailDirection
  state                       EmailMessageState
  stateDetail                 String?             @map("state_detail")
  deliveryState               EmailDeliveryState? @map("delivery_state")
  deliveryStateDetail         String?             @map("delivery_state_detail")
  deliveryStateUpdatedAt      DateTime?           @map("delivery_state_updated_at") @db.Timestamptz(6)
  deliveredAt                 DateTime?           @map("delivered_at") @db.Timestamptz(6)
  resendEmailId               String?             @unique(map: "email_messages_resend_email_id_key") @map("resend_email_id")
  internetMessageId           String?             @unique(map: "email_messages_internet_message_id_key") @map("internet_message_id")
  inReplyToInternetMessageId  String?             @map("in_reply_to_internet_message_id")
  referenceInternetMessageIds String[]            @default([]) @map("reference_internet_message_ids")
  fromAddress                 String              @map("from_address")
  fromName                    String?             @map("from_name")
  toAddress                   String              @map("to_address")
  replyToAddress              String?             @map("reply_to_address")
  subject                     String
  textBody                    String?             @map("text_body")
  htmlBody                    String?             @map("html_body")
  emailCreatedAt              DateTime            @map("email_created_at") @db.Timestamptz(6)
  idempotencyKey              String?             @unique(map: "email_messages_idempotency_key_key") @map("idempotency_key") @db.VarChar(256)
  requestHash                 String?             @map("request_hash") @db.Char(64)
  createdAt                   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  conversation                EmailConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent                      EmailMessage?       @relation("EmailMessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies                     EmailMessage[]      @relation("EmailMessageReplies")
  outboxEntry                 EmailOutboxEntry?

  @@index([conversationId, emailCreatedAt, id], map: "idx_email_messages_conversation_created")
  @@index([inReplyToInternetMessageId], map: "idx_email_messages_in_reply_to")
  @@map("email_messages")
}

model EmailOutboxBatch {
  id             String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  nextAttemptAt  DateTime           @default(now()) @map("next_attempt_at") @db.Timestamptz(6)
  firstAttemptAt DateTime?          @map("first_attempt_at") @db.Timestamptz(6)
  attemptCount   Int                @default(0) @map("attempt_count")
  leaseToken     String?            @map("lease_token") @db.Uuid
  leaseUntil     DateTime?          @map("lease_until") @db.Timestamptz(6)
  lastErrorCode  String?            @map("last_error_code") @db.VarChar(64)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  entries        EmailOutboxEntry[]

  @@index([nextAttemptAt, leaseUntil, id], map: "idx_email_outbox_batches_ready")
  @@map("email_outbox_batches")
}

model EmailOutboxEntry {
  messageId     String            @id @map("message_id") @db.Uuid
  batchId       String?           @map("batch_id") @db.Uuid
  batchPosition Int?              @map("batch_position")
  queuedAt      DateTime          @default(now()) @map("queued_at") @db.Timestamptz(6)
  message       EmailMessage      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  batch         EmailOutboxBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, batchPosition], map: "email_outbox_entries_batch_position_key")
  @@map("email_outbox_entries")
}

model EmailWebhookEvent {
  id                   String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  svixId               String    @unique(map: "resend_wh_emails_svix_id_key") @map("svix_id")
  eventType            String    @map("event_type")
  webhookReceivedAt    DateTime  @default(now()) @map("webhook_received_at") @db.Timestamptz(6)
  eventCreatedAt       DateTime  @map("event_created_at") @db.Timestamptz(6)
  emailId              String    @map("email_id")
  fromAddress          String    @map("from_address")
  toAddresses          String[]  @map("to_addresses")
  subject              String
  emailCreatedAt       DateTime  @map("email_created_at") @db.Timestamptz(6)
  broadcastId          String?   @map("broadcast_id")
  templateId           String?   @map("template_id")
  tags                 Json?     @db.JsonB
  bounceType           String?   @map("bounce_type")
  bounceSubType        String?   @map("bounce_sub_type")
  bounceMessage        String?   @map("bounce_message")
  bounceDiagnosticCode String[]  @default([]) @map("bounce_diagnostic_code")
  deliveryDetail       String?   @map("delivery_detail")
  clickIpAddress       String?   @map("click_ip_address")
  clickLink            String?   @map("click_link")
  clickTimestamp       DateTime? @map("click_timestamp") @db.Timestamptz(6)
  clickUserAgent       String?   @map("click_user_agent")

  @@index([emailId], map: "idx_resend_wh_emails_email_id")
  @@index([eventType], map: "idx_resend_wh_emails_event_type")
  @@index([webhookReceivedAt], map: "idx_resend_wh_emails_webhook_received_at")
  @@index([fromAddress], map: "idx_resend_wh_emails_from_address")
  @@map("resend_wh_emails")
}

model ContactWebhookEvent {
  id                String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  svixId            String   @unique(map: "resend_wh_contacts_svix_id_key") @map("svix_id")
  eventType         String   @map("event_type")
  webhookReceivedAt DateTime @default(now()) @map("webhook_received_at") @db.Timestamptz(6)
  eventCreatedAt    DateTime @map("event_created_at") @db.Timestamptz(6)
  contactId         String   @map("contact_id")
  audienceId        String?  @map("audience_id")
  segmentIds        String[] @default([]) @map("segment_ids")
  email             String
  firstName         String?  @map("first_name")
  lastName          String?  @map("last_name")
  unsubscribed      Boolean  @default(false)
  contactCreatedAt  DateTime @map("contact_created_at") @db.Timestamptz(6)
  contactUpdatedAt  DateTime @map("contact_updated_at") @db.Timestamptz(6)

  @@index([contactId], map: "idx_resend_wh_contacts_contact_id")
  @@index([eventType], map: "idx_resend_wh_contacts_event_type")
  @@index([webhookReceivedAt], map: "idx_resend_wh_contacts_webhook_received_at")
  @@index([audienceId], map: "idx_resend_wh_contacts_audience_id")
  @@index([email], map: "idx_resend_wh_contacts_email")
  @@map("resend_wh_contacts")
}

model DomainWebhookEvent {
  id                String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  svixId            String   @unique(map: "resend_wh_domains_svix_id_key") @map("svix_id")
  eventType         String   @map("event_type")
  webhookReceivedAt DateTime @default(now()) @map("webhook_received_at") @db.Timestamptz(6)
  eventCreatedAt    DateTime @map("event_created_at") @db.Timestamptz(6)
  domainId          String   @map("domain_id")
  name              String
  status            String
  region            String
  domainCreatedAt   DateTime @map("domain_created_at") @db.Timestamptz(6)
  records           Json?    @db.JsonB

  @@index([domainId], map: "idx_resend_wh_domains_domain_id")
  @@index([eventType], map: "idx_resend_wh_domains_event_type")
  @@index([webhookReceivedAt], map: "idx_resend_wh_domains_webhook_received_at")
  @@index([name], map: "idx_resend_wh_domains_name")
  @@map("resend_wh_domains")
}
