# Set this to the connection URL exposed by Railway Postgres
DATABASE_URL=postgresql://user:password@host:5432/database

# Integration tests truncate tables; use a dedicated disposable database
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resend_test

# Shared Resend credential used to retrieve inbound and send outbound email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Get this from the Resend Dashboard when creating the webhook
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Verified sender used only by the private conversation API
RESEND_FROM=Mailbox <mailbox@example.com>

# Long random bearer credential shared with authorized adjacent services
CONVERSATION_API_KEY=replace-with-a-long-random-secret
